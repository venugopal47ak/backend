# Server Environment Variables
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nammaserve
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
SKIP_SERVICE_VALIDATION=false
CLIENT_URL=http://localhost:5173

# Razorpay Credentials
# IMPORTANT: Use rzp_test_* keys for development
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me

# Mail Credentials (Nodemailer)
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=test@example.com
MAIL_PASS=password

# Optional: Enable Demo Mode to test without keys
# Set to 'true' to bypass real Razorpay calls
PAYMENT_DEMO_MODE=false
